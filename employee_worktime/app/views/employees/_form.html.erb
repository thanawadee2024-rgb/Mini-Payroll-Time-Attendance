<%= form_with(model: employee) do |form| %>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
:root{
  --bg:#080b10;--panel:#0f1318;--panel2:#141920;
  --border:#1f2733;--border2:#253040;
  --accent:#00d4aa;--accent-dim:rgba(0,212,170,.12);
  --red:#f87171;--red-dim:rgba(248,113,113,.08);
  --text:#dfe6f0;--muted:#576578;--white:#fff;
  --input-bg:#0c1017;
}
.ef-errors{
  background:var(--red-dim);border:1px solid rgba(248,113,113,.25);
  border-radius:14px;padding:18px 22px;margin-bottom:24px;
}
.ef-errors h2{font-size:13px;font-weight:700;color:var(--red);margin-bottom:10px;}
.ef-errors ul{padding-left:18px;}
.ef-errors li{font-size:13px;color:#fca5a5;margin-bottom:4px;line-height:1.5;}
.ef-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.ef-field{display:flex;flex-direction:column;gap:7px;}
.ef-field.full{grid-column:1/-1;}
.ef-field label{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
.ef-field input{
  background:var(--input-bg);border:1px solid var(--border2);border-radius:10px;
  padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);
  outline:none;width:100%;transition:border-color .2s,box-shadow .2s;
}
.ef-field input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,212,170,.12);}
.ef-field input::placeholder{color:var(--muted);}
.ef-prefix-wrap{position:relative;}
.ef-prefix-wrap .ef-sym{
  position:absolute;left:14px;top:50%;transform:translateY(-50%);
  font-family:'DM Mono',monospace;font-size:13px;color:var(--accent);pointer-events:none;
}
.ef-prefix-wrap input{padding-left:34px;}
.ef-divider{grid-column:1/-1;height:1px;background:var(--border);margin:4px 0;}
.ef-actions{
  grid-column:1/-1;display:flex;align-items:center;
  justify-content:flex-end;gap:10px;padding-top:8px;
}
.ef-btn{
  display:inline-flex;align-items:center;justify-content:center;gap:7px;
  padding:11px 22px;border-radius:10px;font-family:'DM Sans',sans-serif;
  font-size:14px;font-weight:600;text-decoration:none;cursor:pointer;border:none;
  transition:transform .15s,box-shadow .15s;
}
.ef-btn:hover{transform:translateY(-1px);}
.ef-btn-cancel{background:var(--panel2);color:var(--muted);border:1px solid var(--border2);}
.ef-btn-cancel:hover{background:var(--border2);color:var(--text);}
.ef-btn-save{background:var(--accent);color:#030f0c;box-shadow:0 4px 14px rgba(0,212,170,.22);}
.ef-btn-save:hover{box-shadow:0 6px 22px rgba(0,212,170,.35);}
</style>

<% if employee.errors.any? %>
  <div class="ef-errors">
    <h2>⚠ <%= pluralize(employee.errors.count, "error") %> prevented this from saving</h2>
    <ul>
      <% employee.errors.each do |error| %>
        <li><%= error.full_message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="ef-grid">
  <div class="ef-field full">
    <%= form.label :name %>
    <%= form.text_field :name, placeholder: "Full name" %>
  </div>

  <div class="ef-divider"></div>

  <div class="ef-field">
    <%= form.label :position %>
    <%= form.text_field :position, placeholder: "e.g. Software Engineer" %>
  </div>

  <div class="ef-field">
    <%= form.label :base_salary %>
    <div class="ef-prefix-wrap">
      <span class="ef-sym">฿</span>
      <%= form.number_field :base_salary, step: 0.01, placeholder: "0.00" %>
    </div>
  </div>

  <div class="ef-actions">
    <%= link_to "Cancel", employees_path, class: "ef-btn ef-btn-cancel" %>
    <%= form.submit "Save", class: "ef-btn ef-btn-save" %>
  </div>
</div>

<% end %>
