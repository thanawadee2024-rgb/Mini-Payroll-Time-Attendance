<div style="min-height:100vh;background:linear-gradient(135deg,#f8fafc,#ffffff,#ecfdf5);padding:40px 20px;">
  
  <div style="max-width:900px;margin:auto;">

    <div style="margin-bottom:30px;">
      <p style="font-size:14px;font-weight:600;color:#16a34a;margin-bottom:6px;">
        Employee Management
      </p>

      <h1 style="font-size:36px;font-weight:bold;color:#0f172a;margin-bottom:10px;">
        Create New Employee
      </h1>

      <p style="color:#64748b;">
        Add a new employee profile with basic information, salary, and position.
      </p>
    </div>


    <div style="
      background:white;
      border:1px solid #e5e7eb;
      border-radius:18px;
      box-shadow:0 10px 25px rgba(0,0,0,0.08);
      overflow:hidden;
    ">

      <div style="
        background:#f8fafc;
        border-bottom:1px solid #e5e7eb;
        padding:20px 30px;
      ">
        <h2 style="font-size:18px;font-weight:600;color:#1e293b;">
          Employee Information
        </h2>

        <p style="font-size:14px;color:#64748b;margin-top:4px;">
          Please fill in the details below.
        </p>
      </div>


      <div style="padding:30px;">
        <%= render "form", employee: @employee %>
      </div>

    </div>


    <div style="margin-top:20px;">
      <%= link_to "← Back to Employees",
          employees_path,
          style: "font-size:14px;font-weight:500;color:#475569;text-decoration:none;" %>
    </div>

  </div>

</div>