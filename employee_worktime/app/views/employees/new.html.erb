<% content_for :title, "New Employee" %>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
:root{
  --bg:#080b10;--panel:#0f1318;--panel2:#141920;
  --border:#1f2733;--border2:#253040;
  --accent:#00d4aa;--accent-dim:rgba(0,212,170,.12);
  --text:#dfe6f0;--muted:#576578;--white:#fff;
}
  
.ne-wrap{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);color:var(--text);
  min-height:100vh;display:flex;
  justify-content:center;align-items:flex-start;
  padding:48px 20px 80px;position:relative;
}
.ne-wrap::before,.ne-wrap::after{
  content:'';position:fixed;border-radius:50%;
  filter:blur(130px);pointer-events:none;z-index:0;
}
.ne-wrap::before{width:500px;height:500px;background:rgba(0,212,170,.055);top:-100px;right:-120px;}
.ne-wrap::after{width:380px;height:380px;background:rgba(79,142,247,.05);bottom:60px;left:-80px;}

.ne-page{position:relative;z-index:1;width:100%;max-width:680px;}

.ne-back{
  display:inline-flex;align-items:center;gap:6px;
  font-size:13px;color:var(--muted);text-decoration:none;
  margin-bottom:32px;transition:color .2s;
  animation:ne-fadeDown .4s ease both;
}
.ne-back:hover{color:var(--text)}

.ne-eyebrow{
  font-size:11px;font-weight:600;letter-spacing:.18em;
  text-transform:uppercase;color:var(--accent);
  margin-bottom:8px;animation:ne-fadeDown .4s .05s ease both;
  display:flex;align-items:center;gap:8px;
}
.ne-eyebrow .dot{width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 7px var(--accent);}

.ne-title{
  font-size:34px;font-weight:700;color:var(--white);
  letter-spacing:-.5px;line-height:1.1;margin-bottom:4px;
  animation:ne-fadeDown .4s .08s ease both;
}
.ne-subtitle{
  font-size:14px;color:var(--muted);margin-bottom:36px;
  animation:ne-fadeDown .4s .12s ease both;
}

.ne-card{
  background:var(--panel);border:1px solid var(--border);
  border-radius:20px;overflow:hidden;
  animation:ne-fadeUp .5s .15s ease both;position:relative;
}
.ne-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,.02) 0%,transparent 55%);
  pointer-events:none;
}
.ne-card-header{
  padding:22px 28px 20px;border-bottom:1px solid var(--border);
  position:relative;z-index:1;display:flex;align-items:center;gap:12px;
}
.ne-card-icon{
  width:36px;height:36px;border-radius:10px;
  background:var(--accent-dim);border:1px solid rgba(0,212,170,.2);
  display:flex;align-items:center;justify-content:center;font-size:16px;
}
.ne-card-header h2{font-size:15px;font-weight:600;color:var(--white);}
.ne-card-header p{font-size:12px;color:var(--muted);margin-top:2px;}
.ne-card-body{padding:28px;position:relative;z-index:1;}

@keyframes ne-fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
@keyframes ne-fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
</style>

<div class="ne-wrap">
<div class="ne-page">

  <%= link_to employees_path, class: "ne-back" do %>← Back to Employees<% end %>

  <div class="ne-eyebrow"><span class="dot"></span>Employee Management</div>
  <h1 class="ne-title">Create New Employee</h1>
  <p class="ne-subtitle">Add a new employee profile with basic information, salary, and position.</p>

  <div class="ne-card">
    <div class="ne-card-header">
      <div class="ne-card-icon">👤</div>
      <div>
        <h2>Employee Information</h2>
        <p>Please fill in the details below.</p>
      </div>
    </div>
    <div class="ne-card-body">
      <%= render "form", employee: @employee %>
    </div>
  </div>

</div>
</div>
