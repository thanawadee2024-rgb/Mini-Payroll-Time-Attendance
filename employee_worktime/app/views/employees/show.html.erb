<% if notice %>
<div id="successModal" style="display:flex;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;justify-content:center;align-items:center;backdrop-filter:blur(4px);">
  <div style="background:var(--panel);border:1px solid var(--border);padding:32px 36px;border-radius:18px;text-align:center;max-width:380px;animation:scaleIn .25s ease;">
    <div style="font-size:48px;margin-bottom:16px;">✅</div>
    <h3 style="font-size:20px;font-weight:700;margin-bottom:8px;color:var(--white);">Success!</h3>
    <p style="font-size:14px;color:var(--muted);margin-bottom:24px;line-height:1.6;"><%= notice %></p>
    <button onclick="document.getElementById('successModal').style.display='none'" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"
      style="padding:10px 32px;background:var(--accent);color:#000;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:transform .15s;">
      OK
    </button>
  </div>
</div>
<% end %>

<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');

:root{
  --bg:#080b10;--panel:#0f1318;--panel2:#141920;
  --border:#1f2733;--border2:#253040;
  --accent:#00d4aa;--accent-dim:rgba(0,212,170,.12);
  --amber:#f59e0b;--red:#f87171;
  --text:#dfe6f0;--muted:#576578;--white:#fff;
}
*{box-sizing:border-box;margin:0;padding:0}

.ps-body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);color:var(--text);
  min-height:100vh;display:flex;justify-content:center;align-items:flex-start;
  padding:48px 20px 80px;
  position:relative;
}
.ps-body::before,.ps-body::after{
  content:'';position:fixed;border-radius:50%;filter:blur(120px);pointer-events:none;z-index:0;
}
.ps-body::before{width:560px;height:560px;background:rgba(0,212,170,.06);top:-120px;right:-140px;}
.ps-body::after{width:400px;height:400px;background:rgba(79,142,247,.05);bottom:80px;left:-100px;}

.ps-page{position:relative;z-index:1;width:100%;max-width:820px}

.ps-back{
  display:inline-flex;align-items:center;gap:6px;
  font-size:13px;color:var(--muted);text-decoration:none;
  margin-bottom:36px;transition:color .2s;
  animation:ps-fadeDown .4s ease both;
}
.ps-back:hover{color:var(--text)}

.ps-eyebrow{
  font-size:11px;font-weight:600;letter-spacing:.18em;
  text-transform:uppercase;color:var(--muted);
  margin-bottom:10px;animation:ps-fadeDown .4s .05s ease both;
}
.ps-title{
  font-size:36px;font-weight:700;color:var(--white);
  letter-spacing:-.5px;line-height:1.1;
  margin-bottom:40px;animation:ps-fadeDown .4s .1s ease both;
}

.ps-top{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;animation:ps-fadeUp .5s .15s ease both;}

.ps-panel{
  background:var(--panel);border:1px solid var(--border);
  border-radius:18px;padding:28px;position:relative;overflow:hidden;
}
.ps-panel::before{
  content:'';position:absolute;inset:0;border-radius:inherit;
  background:linear-gradient(135deg,rgba(255,255,255,.025) 0%,transparent 60%);
  pointer-events:none;
}

.ps-panel-label{
  font-size:11px;font-weight:600;letter-spacing:.14em;
  text-transform:uppercase;color:var(--muted);
  margin-bottom:22px;display:flex;align-items:center;gap:8px;
}
.ps-panel-label .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent);}

.ps-info-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 0;border-bottom:1px solid var(--border);
}
.ps-info-row:last-child{border-bottom:none}
.ps-info-row .lbl{font-size:13px;color:var(--muted)}
.ps-info-row .val{font-size:14px;font-weight:600;color:var(--text)}

.ps-net{
  background:var(--panel);border:1px solid var(--border);
  border-radius:18px;padding:28px;display:flex;flex-direction:column;
  justify-content:center;position:relative;overflow:hidden;
}
.ps-net::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 30% 50%,rgba(0,212,170,.1) 0%,transparent 65%);
  pointer-events:none;
}
.ps-net-lbl{font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;}
.ps-net-amt{font-family:'DM Mono',monospace;font-size:44px;font-weight:500;color:var(--white);letter-spacing:-1px;line-height:1;}
.ps-net-unit{font-size:18px;color:var(--accent);margin-left:6px;}
.ps-net-badge{
  margin-top:16px;display:inline-flex;align-items:center;gap:6px;
  background:var(--accent-dim);border:1px solid rgba(0,212,170,.2);
  color:var(--accent);font-size:12px;font-weight:600;
  padding:4px 12px;border-radius:20px;width:fit-content;
}

.ps-details{animation:ps-fadeUp .5s .25s ease both;margin-bottom:20px;}
.ps-dtable{width:100%;border-collapse:collapse;}
.ps-dtable tr{transition:background .15s;}
.ps-dtable tr:hover{background:rgba(255,255,255,.02)}
.ps-dtable td{padding:15px 4px;border-bottom:1px solid var(--border);font-size:14px;}
.ps-dtable tr:last-child td{border-bottom:none}
.ps-dtable .dl{color:var(--muted)}
.ps-dtable .dv{text-align:right;font-family:'DM Mono',monospace;font-size:13px;font-weight:500;color:var(--text)}
.ps-dtable .dv.pos{color:var(--accent)}
.ps-dtable .dv.neg{color:var(--red)}
.ps-dtable .divrow td{border-bottom:1px solid var(--border2)!important;padding-bottom:16px!important;}

.ps-actions{display:flex;gap:12px;animation:ps-fadeUp .5s .35s ease both;}
.ps-btn{
  flex:1;display:inline-flex;align-items:center;justify-content:center;gap:8px;
  padding:13px 20px;border-radius:12px;
  font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;
  text-decoration:none;cursor:pointer;transition:transform .15s,box-shadow .2s;
}
.ps-btn:hover{transform:translateY(-2px)}
.ps-btn-edit{background:var(--amber);color:#fff;box-shadow:0 4px 16px rgba(245,158,11,.25);}
.ps-btn-edit:hover{box-shadow:0 6px 22px rgba(245,158,11,.38)}
.ps-btn-back{background:var(--panel2);color:var(--text);border:1px solid var(--border2);}
.ps-btn-back:hover{background:var(--border2)}

@keyframes ps-fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}
@keyframes ps-fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
</style>

<div class="ps-body">
<div class="ps-page">

  <%= link_to employees_path, class: "ps-back" do %>
    ← Back to Employees
  <% end %>

  <p class="ps-eyebrow">Payroll Summary</p>
  <h1 class="ps-title"><%= @employee.name %></h1>

  <div class="ps-top">
    <!-- Employee Info -->
    <div class="ps-panel">
      <div class="ps-panel-label"><span class="dot"></span>Employee Info</div>
      <div class="ps-info-row">
        <span class="lbl">Full Name</span>
        <span class="val"><%= @employee.name %></span>
      </div>
      <div class="ps-info-row">
        <span class="lbl">Position</span>
        <span class="val"><%= @employee.position %></span>
      </div>
    </div>

    <!-- Net Pay -->
    <div class="ps-net">
      <div class="ps-net-lbl">Net Pay</div>
      <div class="ps-net-amt">
        <%= number_to_currency(@employee.net_pay, unit: "", format: "%n").delete(',') %><span class="ps-net-unit">฿</span>
      </div>
      <div class="ps-net-badge">✓ Paid this cycle</div>
    </div>
  </div>

  <!-- Breakdown -->
  <div class="ps-details">
    <div class="ps-panel">
      <div class="ps-panel-label"><span class="dot"></span>Payroll Breakdown</div>
      <table class="ps-dtable">
        <tr>
          <td class="dl">Base Salary</td>
          <td class="dv"><%= number_to_currency(@employee.base_salary, unit: "฿", format: "%n %u") %></td>
        </tr>
        <tr>
          <td class="dl">Work Days</td>
          <td class="dv"><%= @employee.work_days %> days</td>
        </tr>
        <tr class="divrow">
          <td class="dl">OT Hours</td>
          <td class="dv"><%= sprintf("%.2f", @employee.total_ot_hours) %> hrs</td>
        </tr>
        <tr>
          <td class="dl">OT Pay</td>
          <td class="dv pos">+ <%= number_to_currency(@employee.ot_pay, unit: "฿", format: "%n %u") %></td>
        </tr>
        <tr>
          <td class="dl">Tax</td>
          <td class="dv neg">− <%= number_to_currency(@employee.tax, unit: "฿", format: "%n %u") %></td>
        </tr>
      </table>
    </div>
  </div>

  <!-- Actions -->
  <div class="ps-actions">
    <%= link_to "✏️  Edit Employee", edit_employee_path(@employee), class: "ps-btn ps-btn-edit" %>
    <%= link_to "← Back to Employees", employees_path, class: "ps-btn ps-btn-back" %>
  </div>

</div>
</div>
